# ==============================================================================
# MarketMind AI - Environment Variables Template
# ==============================================================================
# Copy this file to '.env' in the same directory and fill in your values.
# The application will auto-fallback to mock providers for external APIs if keys are omitted.

# ------------------------------------------------------------------------------
# System & General Settings
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=5001
HOST=localhost

# ------------------------------------------------------------------------------
# Databases
# ------------------------------------------------------------------------------
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/marketmind?schema=public"

# Redis cache and queue url
REDIS_URL="redis://localhost:6379"

# ------------------------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------------------------
# Generate strong keys for JWT signatures
JWT_SECRET="your_jwt_access_secret_key_change_me_in_production_12345"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_change_me_in_production_12345"

# Token expirations (e.g., 15m, 7d)
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# OAuth Credentials (optional for local mock run)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
OAUTH_REDIRECT_URI="http://localhost:5001/api/v1/auth/oauth/callback"

# ------------------------------------------------------------------------------
# Python ML Service
# ------------------------------------------------------------------------------
ML_SERVICE_PORT=8000
ML_SERVICE_URL="http://localhost:8000"

# ------------------------------------------------------------------------------
# Frontend Variables (Next.js client)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:5001/api/v1"
NEXT_PUBLIC_WS_URL="http://localhost:5001"

# ------------------------------------------------------------------------------
# External API Providers (Leave blank to trigger automatic mock providers)
# ------------------------------------------------------------------------------
# Stock Market APIs
FINNHUB_API_KEY=""
ALPHA_VANTAGE_API_KEY=""
POLYGON_API_KEY=""
TWELVE_DATA_API_KEY=""

# Cryptocurrency APIs
COINGECKO_API_KEY=""
BINANCE_API_KEY=""
BINANCE_SECRET_KEY=""

# General News API
NEWS_API_KEY=""

# AI & LLM APIs
OPENAI_API_KEY=""
GEMINI_API_KEY=""
