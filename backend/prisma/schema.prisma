// ==============================================================================
// Prisma Schema for MarketMind AI
// ==============================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ------------------------------------------------------------------------------
// Enums
// ------------------------------------------------------------------------------

enum Role {
  ADMIN
  USER
}

enum PortfolioType {
  PAPER
  LIVE
}

enum TransactionType {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
}

enum AssetType {
  STOCK
  CRYPTO
}

enum AlertCondition {
  ABOVE
  BELOW
}

enum PredictionType {
  PRICE_FORECAST
  TREND
}

// ------------------------------------------------------------------------------
// Models
// ------------------------------------------------------------------------------

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  firstName    String?
  lastName     String?
  avatarUrl    String?
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  // Relations
  sessions     UserSession[]
  portfolios   Portfolio[]
  watchlists   Watchlist[]
  alerts       Alert[]
  orders       Order[]
  auditLogs    AuditLog[]
  backtestRuns BacktestRun[]
  strategies   Strategy[]
  socialPosts  SocialPost[]
  followers    UserFollow[]       @relation("UserFollowing")
  following    UserFollow[]       @relation("UserFollower")
  quizProgress UserQuizProgress[]
  subscription Subscription?

  @@map("users")
}

model UserSession {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  refreshTokenHash String   @map("refresh_token_hash")
  deviceInfo       String?  @map("device_info")
  ipAddress        String?  @map("ip_address")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now())
  
  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model Portfolio {
  id             String             @id @default(uuid())
  userId         String             @map("user_id")
  name           String
  description    String?
  type           PortfolioType      @default(PAPER)
  balance        Float              @default(100000.0) // Starting cash balance
  currency       String             @default("USD")    // Currency tag (USD, INR, EUR, GBP)
  goalAmount     Float?             @map("goal_amount") // Investment goal
  goalTargetDate DateTime?          @map("goal_target_date") // Goal target date
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  // Relations
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  history      PortfolioHistory[]
  dividends    Dividend[]

  @@map("portfolios")
}

model Asset {
  id            String          @id @default(uuid())
  symbol        String          @unique
  name          String
  type          AssetType
  exchange      String?
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now())
  
  // Relations
  transactions  Transaction[]
  orders        Order[]
  watchlistItems WatchlistItem[]
  alerts        Alert[]
  predictions   Prediction[]
  dividends     Dividend[]

  @@map("assets")
}

model Transaction {
  id              String          @id @default(uuid())
  portfolioId     String          @map("portfolio_id")
  assetId         String          @map("asset_id")
  type            TransactionType
  quantity        Float
  pricePerUnit    Float           @map("price_per_unit")
  fee             Float           @default(0.0)
  transactionDate DateTime        @default(now()) @map("transaction_date")
  
  // Relations
  portfolio       Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset           Asset           @relation(fields: [assetId], references: [id])
  journalEntry    TradeJournalEntry?

  @@map("transactions")
}

model PortfolioHistory {
  id          String    @id @default(uuid())
  portfolioId String    @map("portfolio_id")
  timestamp   DateTime  @default(now())
  totalValue  Float     @map("total_value") // Cash balance + Asset holdings value
  cashBalance Float     @map("cash_balance")
  
  // Relations
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("portfolio_history")
}

model Watchlist {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  name      String
  createdAt DateTime        @default(now())
  
  // Relations
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]

  @@map("watchlists")
}

model WatchlistItem {
  watchlistId String   @map("watchlist_id")
  assetId     String   @map("asset_id")
  addedAt     DateTime @default(now()) @map("added_at")
  
  // Relations
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([watchlistId, assetId])
  @@map("watchlist_items")
}

model Alert {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  assetId      String         @map("asset_id")
  triggerPrice Float          @map("trigger_price")
  condition    AlertCondition
  isTriggered  Boolean        @default(false) @map("is_triggered")
  createdAt    DateTime       @default(now())
  triggeredAt  DateTime?      @map("triggered_at")
  
  // Relations
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset        Asset          @relation(fields: [assetId], references: [id])

  @@map("alerts")
}

model Order {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  assetId   String      @map("asset_id")
  type      TransactionType
  orderType OrderType   @map("order_type")
  status    OrderStatus @default(PENDING)
  quantity  Float
  price     Float
  createdAt DateTime    @default(now())
  
  // Relations
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset       @relation(fields: [assetId], references: [id])

  @@map("orders")
}

model Prediction {
  id              String         @id @default(uuid())
  assetId         String         @map("asset_id")
  predictionType  PredictionType @map("prediction_type")
  predictedValue  Float          @map("predicted_value")
  confidenceScore Float          @map("confidence_score")
  timestamp       DateTime       @default(now())
  
  // Relations
  asset           Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("predictions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  ipAddress String?  @map("ip_address")
  timestamp DateTime @default(now())
  
  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Dividend {
  id           String    @id @default(uuid())
  portfolioId  String    @map("portfolio_id")
  assetId      String    @map("asset_id")
  amount       Float
  exDate       DateTime  @map("ex_date")
  paymentDate  DateTime  @map("payment_date")
  
  // Relations
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset        Asset     @relation(fields: [assetId], references: [id])

  @@map("dividends")
}

model BacktestRun {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  strategyName String    @map("strategy_name")
  assetSymbol  String    @map("asset_symbol")
  startBalance Float     @map("start_balance")
  endBalance   Float     @map("end_balance")
  cagr         Float
  sharpeRatio  Float     @map("sharpe_ratio")
  maxDrawdown  Float     @map("max_drawdown")
  winRate      Float?    @map("win_rate")
  profitFactor Float?    @map("profit_factor")
  equityCurve  Json?     @map("equity_curve")
  tradesList   Json?     @map("trades_list")
  createdAt    DateTime  @default(now())

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("backtest_runs")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

// ------------------------------------------------------------------------------
// New Ecosystem Models
// ------------------------------------------------------------------------------

model Strategy {
  id         String   @id @default(uuid())
  name       String
  type       String   // e.g. "EMA_CROSSOVER", "RSI", "MACD", "CUSTOM"
  parameters Json     // holds indicator configurations, risk management, stop-loss rules
  userId     String   @map("user_id")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("strategies")
}

model TradeJournalEntry {
  id            String   @id @default(uuid())
  transactionId String   @unique @map("transaction_id")
  notes         String
  sentiment     String   // "BULLISH", "BEARISH", "NEUTRAL"
  createdAt     DateTime @default(now())
  
  // Relations
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("trade_journal_entries")
}

model Course {
  id          String   @id @default(uuid())
  title       String
  category    String   // e.g. "Technical Analysis", "Beginner Investing"
  description String
  level       String   // "BEGINNER", "INTERMEDIATE", "ADVANCED"
  createdAt   DateTime @default(now())
  
  // Relations
  quizzes     Quiz[]

  @@map("courses")
}

model Quiz {
  id                 String             @id @default(uuid())
  courseId           String             @map("course_id")
  question           String
  options            String[]           // Array of option texts
  correctAnswerIndex Int                @map("correct_answer_index")
  createdAt          DateTime           @default(now())
  
  // Relations
  course             Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userProgress       UserQuizProgress[]

  @@map("quizzes")
}

model UserQuizProgress {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  quizId      String   @map("quiz_id")
  completed   Boolean  @default(false)
  score       Float    @default(0.0)
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("user_quiz_progress")
}

model SocialPost {
  id         String   @id @default(uuid())
  content    String
  authorId   String   @map("author_id")
  symbol     String?  // Linked stock/crypto asset symbol
  likesCount Int      @default(0) @map("likes_count")
  createdAt  DateTime @default(now())
  
  // Relations
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("social_posts")
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now())
  
  // Relations
  follower    User     @relation("UserFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("user_follows")
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  status               String    // "ACTIVE", "PAST_DUE", "CANCELED", "FREE"
  planTier             String    @default("FREE") @map("plan_tier") // "FREE", "PRO", "ENTERPRISE"
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  // Relations
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices             Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id             String   @id @default(uuid())
  subscriptionId String   @map("subscription_id")
  amount         Float
  pdfUrl         String?  @map("pdf_url")
  issuedAt       DateTime @default(now()) @map("issued_at")
  
  // Relations
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("invoices")
}
